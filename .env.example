# Copy this file to `.env` and fill in real values if you have them.
# If you leave the AWS keys blank, the system automatically runs in
# offline MOCK mode (no AWS account required) -- see app/services/llm_service.py

# ----- App -----
APP_ENV=development
LOG_LEVEL=INFO

# ----- API Server -----
API_HOST=0.0.0.0
API_PORT=8000

# ----- AWS Bedrock (optional) -----
# Leave these blank to run fully offline with the mock LLM.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.3

# Set to false to force a real Bedrock call when credentials ARE present.
# (It's automatically true/mock whenever credentials are missing, regardless of this flag.)
USE_MOCK_LLM=true

# ----- Simulation Engine -----
SIMULATION_RUNS=1000
RISK_ESCALATION_THRESHOLD=0.65
MAX_SIMULATION_RETRIES=2

# ----- Forecasting -----
FORECAST_HORIZON_MONTHS=12

# ----- Reports -----
REPORTS_DIR=data/reports
